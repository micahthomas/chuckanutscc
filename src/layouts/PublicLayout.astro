---
import "~/styles/global.css";
import interLatin from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import { db } from "~/lib/db";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Chuckanut Sports Car Club` : "Chuckanut Sports Car Club";

// Top nav is a fixed five-link list, kept short on purpose. Secondary pages
// (Locations, Shop, Contact, Photographers, etc.) live in the footer sitemap.
const primaryNav: Array<{ href: string; label: string }> = [
  { href: "/events",          label: "Events" },
  { href: "/autocross",       label: "Autocross" },
  { href: "/membership",      label: "Membership" },
  { href: "/gallery",         label: "Gallery" },
  { href: "/about",           label: "About" },
];

// Grouped footer "sitemap" — sections + label/href tuples, easy to extend.
const footerColumns: Array<{ heading: string; links: Array<{ href: string; label: string }> }> = [
  {
    heading: "Get involved",
    links: [
      { href: "/events",            label: "Events" },
      { href: "/membership",        label: "Membership" },
      { href: "/autocross",         label: "Autocross intro" },
      { href: "/autocross-rules",   label: "Autocross rules" },
    ],
  },
  {
    heading: "Club",
    links: [
      { href: "/about",             label: "About" },
      { href: "/locations",         label: "Locations" },
      { href: "/gallery",           label: "Gallery" },
      { href: "/shop",              label: "Shop" },
    ],
  },
  {
    heading: "Connect",
    links: [
      { href: "/contact",           label: "Contact" },
    ],
  },
];

const { results: settingsRows } = await db(Astro)
  .prepare(`SELECT key, value FROM settings WHERE key IN ('logo_key', 'social_instagram_url', 'social_facebook_url')`)
  .all<{ key: string; value: string }>();
const settingsMap = Object.fromEntries(settingsRows.map((r) => [r.key, r.value]));
const logoKey = settingsMap.logo_key;
const instagramUrl = settingsMap.social_instagram_url;
const facebookUrl = settingsMap.social_facebook_url;

const flash = Astro.url.searchParams.get("flash");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    {/* Preload the Inter variable file so it arrives before first paint.
        Without this the browser renders system-ui then visibly swaps. */}
    <link rel="preload" as="font" type="font/woff2" href={interLatin} crossorigin />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#f97316" />
  </head>
  <body class="min-h-screen flex flex-col bg-zinc-950 text-zinc-100">
    <header class="border-b border-zinc-800">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 font-display text-lg sm:text-xl font-semibold text-brand-700 min-w-0">
          {logoKey && <img src={`/media/${logoKey}`} alt="" class="w-9 h-9 shrink-0" />}
          <span class="truncate">Chuckanut Sports Car Club</span>
        </a>

        {/* Desktop nav (md+) — five primary links; rest live in the footer. */}
        <nav class="hidden md:flex flex-wrap gap-x-6 gap-y-2 text-sm">
          {primaryNav.map((item) => (
            <a href={item.href} class="hover:text-brand-500">{item.label}</a>
          ))}
        </nav>

        {/* Mobile hamburger toggle (under md) */}
        <button
          id="mobile-nav-toggle"
          type="button"
          class="md:hidden -m-2 p-2 text-zinc-300 hover:bg-zinc-800 rounded shrink-0"
          aria-label="Open menu"
          aria-controls="mobile-nav"
          aria-expanded="false"
        >
          <svg id="mobile-nav-open"  class="w-6 h-6"        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="mobile-nav-close" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
        </button>
      </div>

      {/* Mobile nav (under md). Hidden by default; toggle script below. */}
      <nav
        id="mobile-nav"
        class="md:hidden hidden flex-col px-2 pb-3 text-base border-t border-zinc-800"
      >
        {primaryNav.map((item) => (
          <a href={item.href} class="block px-3 py-3 rounded hover:bg-zinc-800">{item.label}</a>
        ))}
      </nav>
    </header>

    <script is:inline>
      (() => {
        const btn = document.getElementById("mobile-nav-toggle");
        const nav = document.getElementById("mobile-nav");
        const open = document.getElementById("mobile-nav-open");
        const close = document.getElementById("mobile-nav-close");
        if (!btn || !nav) return;
        btn.addEventListener("click", () => {
          const wasOpen = btn.getAttribute("aria-expanded") === "true";
          btn.setAttribute("aria-expanded", String(!wasOpen));
          btn.setAttribute("aria-label", wasOpen ? "Open menu" : "Close menu");
          nav.classList.toggle("hidden");
          nav.classList.toggle("flex");
          open?.classList.toggle("hidden", !wasOpen);
          close?.classList.toggle("hidden", wasOpen);
        });
      })();
    </script>

    {flash && (
      <div class="bg-emerald-50 border-b border-emerald-200 text-emerald-900">
        <div class="max-w-6xl mx-auto px-4 py-2 text-sm">{flash}</div>
      </div>
    )}

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-zinc-800 mt-16 print:hidden">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
          <div class="md:col-span-1">
            <div class="flex items-center gap-2 mb-3">
              {logoKey && <img src={`/media/${logoKey}`} alt="" class="w-8 h-8" />}
              <span class="font-display text-base font-semibold text-brand-700">CSCC</span>
            </div>
            <p class="text-sm text-zinc-400 leading-relaxed">
              Chuckanut Sports Car Club &mdash; Bellingham, WA. Founded 1956. Autocross, rallies, tours, and social events.
            </p>
          </div>

          {footerColumns.map((col) => (
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-3">
                {col.heading}
              </h3>
              <ul class="space-y-2 text-sm">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-zinc-300 hover:text-brand-500">{link.label}</a>
                  </li>
                ))}
              </ul>
              {col.heading === "Connect" && (instagramUrl || facebookUrl) && (
                <div class="flex items-center gap-1 mt-3 -ml-2">
                  {instagramUrl && (
                    <a href={instagramUrl} target="_blank" rel="noopener" aria-label="Instagram"
                      class="inline-flex items-center justify-center w-10 h-10 text-zinc-500 hover:text-brand-700 hover:bg-zinc-800 rounded transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                      </svg>
                    </a>
                  )}
                  {facebookUrl && (
                    <a href={facebookUrl} target="_blank" rel="noopener" aria-label="Facebook"
                      class="inline-flex items-center justify-center w-10 h-10 text-zinc-500 hover:text-brand-700 hover:bg-zinc-800 rounded transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                      </svg>
                    </a>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>

        <div class="border-t border-zinc-800 mt-10 pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-zinc-500">
          <span>&copy; {new Date().getFullYear()} Chuckanut Sports Car Club &middot; Bellingham, WA</span>
          <span>
            <a href="https://www.chuckanutscc.org" class="hover:text-brand-500">chuckanutscc.org</a>
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
