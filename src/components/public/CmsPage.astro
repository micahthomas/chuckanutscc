---
/**
 * Shared chrome for every editorial page. Wraps PageHero + the markdown body,
 * with optional sticky TOC sidebar (built from H2 headings) and an optional
 * print button. Used by [slug].astro for every page in the `pages` table.
 *
 * The print stylesheet is scoped here so any CmsPage prints cleanly even if
 * the author didn't flip on the print button — Ctrl-P still works.
 */
import PageHero, { type HeroCta } from "./PageHero.astro";
import { renderMarkdownWithToc } from "~/lib/markdown";
import { db } from "~/lib/db";

interface Props {
  title: string;
  eyebrow?: string;
  subtitle?: string;
  bodyMd: string;
  items?: string[];
  ctas?: HeroCta[];
  heroImageKey?: string | null;
  statValue?: string;
  statLabel?: string;
  showToc?: boolean;
  showPrint?: boolean;
  footnote?: string;
}

const {
  title,
  eyebrow,
  subtitle,
  bodyMd,
  items,
  ctas,
  heroImageKey,
  statValue,
  statLabel,
  showToc = false,
  showPrint = false,
  footnote,
} = Astro.props;

// Drop a leading `# Title` from the markdown — the hero already covers it.
// Older seed rows put the title back into the body for the basic [slug].astro
// hero, which would otherwise render twice.
const trimmed = bodyMd.replace(/^#\s+.*\n+/, "");
const { html, toc } = renderMarkdownWithToc(trimmed);
const hasToc = showToc && toc.length > 1;

// Print cover + running header/footer. Only loaded for show_print pages so
// regular pages don't pay for a settings query.
let logoKey: string | null = null;
if (showPrint) {
  const row = await db(Astro)
    .prepare(`SELECT value FROM settings WHERE key = 'logo_key'`)
    .first<{ value: string }>();
  logoKey = row?.value ?? null;
}

// CSS escape for use inside `content: "…"` strings. Page titles rarely contain
// quotes but be defensive — a stray `"` would otherwise break the @page rule.
const cssEscape = (s: string) => s.replace(/[\\"]/g, "\\$&");
const printHeaderTitle = cssEscape(title);
const printHeaderRev = cssEscape(eyebrow ?? "");
const printFooterDomain = "chuckanutscc.org";
---

{showPrint && (
  <aside class="print-cover" aria-hidden="true">
    {logoKey && <img src={`/media/${logoKey}`} alt="" class="print-cover-logo" />}
    {eyebrow && <div class="print-cover-eyebrow">{eyebrow}</div>}
    <h1 class="print-cover-title">{title}</h1>
    {subtitle && <p class="print-cover-subtitle">{subtitle}</p>}
    <div class="print-cover-domain">{printFooterDomain}</div>
  </aside>
)}

{showPrint && (
  <style is:inline set:html={`
    @media print {
      @page {
        size: letter;
        margin: 0.9in 0.75in 0.7in;
        @top-left     { content: "${printHeaderTitle}"; font-size: 9pt; color: #555; }
        @top-right    { content: "${printHeaderRev}";   font-size: 9pt; color: #555; }
        @bottom-left  { content: "${printFooterDomain}"; font-size: 9pt; color: #555; }
        @bottom-right { content: "page " counter(page);  font-size: 9pt; color: #555; }
      }
      /* Cover page = no running header/footer, no margins; the .print-cover
         block paints the whole page itself. */
      @page :first {
        margin: 0;
        @top-left     { content: ""; }
        @top-right    { content: ""; }
        @bottom-left  { content: ""; }
        @bottom-right { content: ""; }
      }
    }
  `} />
)}

{/* When a print cover is rendered, the on-screen hero would print *again* on
    page 2 (h1 + subtitle), duplicating the cover. Wrap it so it's hidden on
    print for show_print pages. */}
<div class={showPrint ? "print:hidden" : ""}>
  <PageHero
    eyebrow={eyebrow}
    title={title}
    subtitle={subtitle}
    items={items}
    ctas={ctas}
    heroImageKey={heroImageKey}
    statValue={statValue}
    statLabel={statLabel}
  />
</div>

{showPrint && (
  <div class="border-b border-zinc-800 bg-zinc-950 print:hidden">
    <div class="max-w-5xl mx-auto px-4 py-3 flex justify-end">
      <button
        type="button"
        id="print-cms-page"
        class="inline-flex items-center gap-2 text-sm border border-zinc-700 text-zinc-100 px-3 py-1.5 rounded hover:bg-zinc-900"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 6 2 18 2 18 9" />
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
          <rect x="6" y="14" width="12" height="8" />
        </svg>
        Print or save as PDF
      </button>
    </div>
  </div>
)}

{hasToc ? (
  <div class="cms-page-wrap max-w-6xl mx-auto px-4 py-10 lg:py-12 grid gap-10 lg:grid-cols-[16rem_1fr] print:block print:py-0">
    {/* Mobile/tablet TOC — collapsed by default. */}
    <details class="lg:hidden bg-zinc-900 border border-zinc-800 rounded p-4 print:hidden">
      <summary class="cursor-pointer font-semibold text-zinc-100">Jump to section</summary>
      <ul class="mt-3 space-y-1.5 text-sm">
        {toc.map((item) => (
          <li><a href={`#${item.id}`} class="text-brand-500 hover:text-brand-300">{item.label}</a></li>
        ))}
      </ul>
    </details>

    {/* Desktop sticky TOC. */}
    <aside class="hidden lg:block print:hidden">
      <nav aria-label="Sections" class="sticky top-6">
        <div class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-3">Contents</div>
        <ul class="space-y-2 text-sm border-l border-zinc-800">
          {toc.map((item) => (
            <li>
              <a href={`#${item.id}`} class="block pl-3 -ml-px border-l border-transparent text-zinc-300 hover:text-brand-500 hover:border-brand-500">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="prose max-w-none cms-body">
      <div set:html={html} />
      {footnote && <p class="text-sm text-zinc-500 print:text-black mt-8">{footnote}</p>}
    </article>
  </div>
) : (
  <article class="cms-page-wrap max-w-3xl mx-auto px-4 py-12 cms-body">
    <div class="prose max-w-none" set:html={html} />
    {footnote && <p class="text-sm text-zinc-500 print:text-black mt-8 prose">{footnote}</p>}
  </article>
)}

{showPrint && (
  <script is:inline>
    document.getElementById("print-cms-page")?.addEventListener("click", () => window.print());
  </script>
)}

<style>
  /* Section anchor offset so deep-link jumps don't hide under the sticky nav. */
  .cms-body :global(h2),
  .cms-body :global(h3) { scroll-margin-top: 1.5rem; }
  /* H2 visual separator on TOC-enabled pages reads as section dividers. */
  .cms-body :global(h2) { border-bottom: 1px solid #27272a; padding-bottom: 0.5rem; }

  /* Cover page is invisible on screen — it only exists for the print layout. */
  .print-cover { display: none; }

  @media print {
    :global(html), :global(body) { background: #fff !important; color: #000 !important; }
    :global(body) { font-size: 11pt; }
    :global(header), :global(footer) { display: none !important; }
    :global(main) { padding: 0 !important; }
    .cms-body, .cms-body :global(*) { color: #000 !important; }
    .cms-body :global(a) { color: #000 !important; text-decoration: underline; }
    .cms-body :global(h2) {
      border-bottom: 1px solid #000 !important;
      page-break-after: avoid;
    }
    .cms-body :global(h3) { page-break-after: avoid; }
    .cms-body :global(blockquote) {
      border-left: 2px solid #000 !important;
      color: #000 !important;
      font-style: italic;
    }

    /* Strip the screen-only max-width / horizontal padding so the article
       fills the @page printable area edge-to-edge without overflow clipping.
       Targeted via .cms-page-wrap rather than Tailwind print: variants because
       the latter didn't reach the compiled CSS in dev. */
    .cms-page-wrap {
      max-width: none !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }

    /* Cover page: page-break-after: always pushes the rest of the document to
       page 2. The @page :first rule (in the inline <style> above) strips the
       running header/footer margin boxes so this page is clean. */
    .print-cover {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-sizing: border-box;
      min-height: 100vh;
      width: 100%;
      padding: 1in;
      background: #fff;
      color: #000;
      page-break-after: always;
    }
    .print-cover-logo {
      width: 2.5in;
      height: auto;
      margin-bottom: 0.75in;
    }
    .print-cover-eyebrow {
      font-size: 11pt;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #555;
      margin-bottom: 0.75rem;
    }
    .print-cover-title {
      font-size: 32pt;
      font-weight: 700;
      line-height: 1.15;
      margin: 0;
      max-width: 5in;
    }
    .print-cover-subtitle {
      font-size: 11pt;
      color: #444;
      max-width: 5in;
      margin-top: 0.75rem;
    }
    .print-cover-domain {
      margin-top: auto;
      font-size: 10pt;
      color: #888;
    }
  }
</style>
