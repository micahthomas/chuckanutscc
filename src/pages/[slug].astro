---
import PublicLayout from "~/layouts/PublicLayout.astro";
import CmsPage from "~/components/public/CmsPage.astro";
import type { HeroCta } from "~/components/public/PageHero.astro";
import { loadPageBySlug } from "~/lib/queries";

const slug = Astro.params.slug!;
const page = await loadPageBySlug(Astro, slug);

if (!page) {
  return new Response("Not found", { status: 404 });
}

function parseStringArray(json: string): string[] {
  try {
    const parsed = JSON.parse(json);
    return Array.isArray(parsed) ? parsed.filter((s): s is string => typeof s === "string") : [];
  } catch {
    return [];
  }
}
function parseCtas(json: string): HeroCta[] {
  try {
    const parsed = JSON.parse(json);
    if (!Array.isArray(parsed)) return [];
    return parsed.filter(
      (c): c is HeroCta =>
        c && typeof c === "object" && typeof c.label === "string" && typeof c.href === "string",
    );
  } catch {
    return [];
  }
}

const items = parseStringArray(page.hero_items_json);
const ctas = parseCtas(page.hero_ctas_json);

// Eyebrow defaults to "Club" for simple pages with nothing else in the hero,
// so they don't lose the small label the previous one-off template had. Rich
// pages (autocross, rules) set their own eyebrow.
const fallbackEyebrow = !page.eyebrow && !items.length && !ctas.length && !page.hero_image_key
  ? "Club"
  : page.eyebrow;
---

<PublicLayout
  title={page.seo_title ?? page.title}
  description={page.seo_description ?? page.subtitle ?? undefined}
>
  <CmsPage
    title={page.title}
    eyebrow={fallbackEyebrow || undefined}
    subtitle={page.subtitle || undefined}
    bodyMd={page.body_md}
    items={items}
    ctas={ctas}
    heroImageKey={page.hero_image_key}
    statValue={page.hero_stat_value || undefined}
    statLabel={page.hero_stat_label || undefined}
    showToc={page.show_toc === 1}
    showPrint={page.show_print === 1}
  />
</PublicLayout>
