---
import PhotographerLayout from "~/layouts/PhotographerLayout.astro";
import PhotographerUploader from "~/components/photographer/PhotographerUploader";
import PhotographerPhotoManager from "~/components/photographer/PhotographerPhotoManager";
import { assertPhotographerEvent } from "~/lib/photographer-auth";
import { loadEventPhotos } from "~/lib/queries";
import { fmtDate } from "~/lib/format";

const token = Astro.params.token!;
const eventId = Astro.params.eventId!;

let session;
try {
  session = await assertPhotographerEvent(Astro, token, eventId);
} catch (r) {
  if (r instanceof Response) return r;
  throw r;
}
const { photographer, event } = session;

const photos = await loadEventPhotos(Astro, event.id, {
  status: "all",
  photographerId: photographer.id,
});
---

<PhotographerLayout
  title={event.title}
  photographerName={photographer.name}
  backToToken={token}
>
  <h1 class="text-2xl font-semibold">{event.title}</h1>
  <p class="text-sm text-zinc-400 mt-1 mb-8">{fmtDate(event.start_at)}</p>

  <section class="mb-12">
    <h2 class="text-lg font-semibold mb-3">Upload photos</h2>
    <p class="text-sm text-zinc-400 mb-4">
      Drop files, pick multiple, or upload a ZIP. Each photo is resized and
      uploaded in your browser — feel free to close the tab and come back
      later; what's already uploaded will stay.
    </p>
    <PhotographerUploader
      client:load
      token={token}
      eventId={event.id}
    />
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-3">
      Your photos for this event
      <span class="text-sm font-normal text-zinc-400">({photos.length})</span>
    </h2>
    <PhotographerPhotoManager
      client:load
      token={token}
      eventId={event.id}
      initialPhotos={photos.map((p) => ({
        id: p.id,
        filename: p.filename,
        r2_key_thumb: p.r2_key_thumb,
        status: p.status,
      }))}
    />
  </section>
</PhotographerLayout>
