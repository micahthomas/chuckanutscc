---
import PhotographerLayout from "~/layouts/PhotographerLayout.astro";
import { db } from "~/lib/db";
import { findPhotographerByToken } from "~/lib/photographer-auth";
import { fmtDate } from "~/lib/format";

const token = Astro.params.token!;
const photographer = await findPhotographerByToken(Astro, token);
if (!photographer) {
  return new Response("Not found", { status: 404 });
}

interface AssignedEvent {
  id: string;
  slug: string;
  title: string;
  start_at: number;
  status: string;
  location_name: string | null;
  photo_count: number;
  cover_thumb: string | null;
}

const { results: events } = await db(Astro)
  .prepare(
    `SELECT e.id, e.slug, e.title, e.start_at, e.status, e.location_name,
            COUNT(ph.id) AS photo_count,
            (SELECT r2_key_thumb FROM photos
             WHERE event_id = e.id AND photographer_id = ?
             ORDER BY COALESCE(sort_order, 999999), COALESCE(exif_taken_at, uploaded_at)
             LIMIT 1) AS cover_thumb
     FROM events e
     JOIN event_photographers ep ON ep.event_id = e.id
     LEFT JOIN photos ph
       ON ph.event_id = e.id AND ph.photographer_id = ep.photographer_id
     WHERE ep.photographer_id = ?
     GROUP BY e.id
     ORDER BY e.start_at DESC`,
  )
  .bind(photographer.id, photographer.id)
  .all<AssignedEvent>();
---

<PhotographerLayout title="Your events" photographerName={photographer.name}>
  <h1 class="text-2xl font-semibold mb-2">Welcome, {photographer.name}</h1>
  <p class="text-sm text-slate-600 mb-8">
    These are the events you've been assigned to. Pick one to upload or manage
    photos.
  </p>

  {events.length === 0 ? (
    <p class="text-sm text-slate-500">
      No events assigned yet. A club officer will assign you to events from the
      admin area.
    </p>
  ) : (
    <ul class="grid gap-3 sm:grid-cols-2">
      {events.map((evt) => (
        <li>
          <a
            href={`/p/${token}/${evt.id}`}
            class="block bg-white border border-slate-200 rounded overflow-hidden hover:border-brand-700 hover:shadow-sm transition"
          >
            <div class="aspect-video bg-slate-100 overflow-hidden">
              {evt.cover_thumb ? (
                <img
                  src={`/media/${evt.cover_thumb}`}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-slate-400 text-xs">
                  No photos yet
                </div>
              )}
            </div>
            <div class="p-3">
              <div class="font-semibold text-sm">{evt.title}</div>
              <div class="text-xs text-slate-500 mt-1">
                {fmtDate(evt.start_at)}{evt.location_name ? ` · ${evt.location_name}` : ""}
              </div>
              <div class="text-xs text-slate-400 mt-2">
                {evt.photo_count} photo{evt.photo_count === 1 ? "" : "s"} uploaded
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</PhotographerLayout>
