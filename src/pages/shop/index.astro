---
import PublicLayout from "~/layouts/PublicLayout.astro";
import { loadMerchItems } from "~/lib/queries";

interface ProductImage { r2_key: string; alt: string; caption?: string }

const items = (await loadMerchItems(Astro, { availableOnly: true })).map((item) => {
  const images: ProductImage[] = JSON.parse(item.images_json || "[]");
  return {
    ...item,
    primaryImage: images[0] ?? null,
    preview: item.description_md.replace(/[#*_`]/g, "").trim().slice(0, 140),
  };
});
---

<PublicLayout title="Shop" description="CSCC swag and merchandise.">
  <section class="border-b border-zinc-800 bg-zinc-900">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-500 mb-3">Merch</div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-3">Shop</h1>
      <p class="text-zinc-400 max-w-2xl">
        CSCC swag is available at any Chuckanut Event, but is limited to colors, styles and sizes
        on hand. To request a product to be included in our next order, click an item below.
        Swag is purchased near the beginning and end of each season.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-12">
    {items.length === 0 && (
      <p class="text-zinc-400">Nothing available right now — check back next season.</p>
    )}

    {items.length > 0 && (
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <li>
            <a
              href={`/shop/${item.slug}`}
              class="group block bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-brand-500 hover:shadow-lg transition-all h-full flex flex-col"
            >
              <div class="aspect-[4/5] bg-gradient-to-br from-brand-700 to-brand-900 overflow-hidden">
                {item.primaryImage ? (
                  <img
                    src={`/media/${item.primaryImage.r2_key}`}
                    alt={item.primaryImage.alt || item.title}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-white/70 text-sm uppercase tracking-wider">
                    {item.title.slice(0, 1)}
                  </div>
                )}
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <h2 class="font-display text-lg font-semibold mb-1">{item.title}</h2>
                <p class="text-sm text-zinc-400 mb-3 line-clamp-2">{item.preview}</p>
                {item.notes && (
                  <p class="text-xs text-zinc-400 italic mb-3">{item.notes}</p>
                )}
                <span class="mt-auto text-sm text-brand-700 group-hover:underline font-medium">
                  Request →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</PublicLayout>
