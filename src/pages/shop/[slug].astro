---
import PublicLayout from "~/layouts/PublicLayout.astro";
import { loadMerchItemBySlug } from "~/lib/queries";
import { renderMarkdown } from "~/lib/markdown";

const slug = Astro.params.slug!;
const item = await loadMerchItemBySlug(Astro, slug);

if (!item) {
  return new Response("Not found", { status: 404 });
}

interface Option {
  name: string;
  choices: string[];
}
interface ProductImage { r2_key: string; alt: string; caption?: string }

const options: Option[] = JSON.parse(item.options_json || "[]");
const images: ProductImage[] = JSON.parse(item.images_json || "[]");
const descHtml = renderMarkdown(item.description_md);
---

<PublicLayout title={item.title}>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <a href="/shop" class="text-sm text-zinc-400 hover:text-zinc-200">← All items</a>
    <h1 class="font-display text-3xl sm:text-4xl font-bold mt-4 mb-8">{item.title}</h1>

    <div class="grid gap-8 md:grid-cols-2">
      <div>
        {images.length > 0 ? (
          <div class="space-y-3">
            <div class="aspect-[4/5] bg-zinc-800 rounded-lg overflow-hidden border border-zinc-800">
              <img
                src={`/media/${images[0].r2_key}`}
                alt={images[0].alt || item.title}
                class="w-full h-full object-cover"
              />
            </div>
            {images.length > 1 && (
              <div class="grid grid-cols-4 gap-2">
                {images.slice(1).map((img) => (
                  <div class="aspect-square bg-zinc-800 rounded overflow-hidden border border-zinc-800">
                    <img
                      src={`/media/${img.r2_key}`}
                      alt={img.alt}
                      loading="lazy"
                      class="w-full h-full object-cover"
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="aspect-[4/5] bg-gradient-to-br from-brand-700 to-brand-900 rounded-lg flex items-center justify-center text-white/60 text-sm uppercase tracking-wider">
            No image yet
          </div>
        )}
      </div>

      <div>
        <div class="prose prose-sm text-zinc-300 mb-5" set:html={descHtml} />
        {item.notes && (
          <p class="text-xs text-zinc-400 italic mb-5">{item.notes}</p>
        )}

        <form method="post" action="/api/merch/request" class="border border-zinc-800 rounded-lg p-5 bg-zinc-900">
          <h2 class="font-semibold mb-4">Request this item</h2>
          <input type="hidden" name="item_id" value={item.id} />
          <input type="hidden" name="item_slug" value={item.slug} />

          <div class="grid grid-cols-1 gap-3 mb-4">
            <label class="block">
              <span class="text-sm font-medium text-zinc-300">Your name</span>
              <input type="text" name="name" required
                class="mt-1 w-full border border-zinc-700 rounded px-3 py-2 text-sm" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-zinc-300">Email</span>
              <input type="email" name="email" required
                class="mt-1 w-full border border-zinc-700 rounded px-3 py-2 text-sm" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-zinc-300">Quantity</span>
              <input type="number" name="quantity" min="1" value="1" required
                class="mt-1 w-full border border-zinc-700 rounded px-3 py-2 text-sm" />
            </label>

            {options.map((opt) => (
              <label class="block">
                <span class="text-sm font-medium text-zinc-300">{opt.name}</span>
                <select name={`opt_${opt.name}`} required
                  class="mt-1 w-full border border-zinc-700 rounded px-3 py-2 text-sm bg-zinc-900">
                  <option value="">— choose —</option>
                  {opt.choices.map((c) => <option value={c}>{c}</option>)}
                </select>
              </label>
            ))}

            <label class="block">
              <span class="text-sm font-medium text-zinc-300">Notes (optional)</span>
              <textarea name="notes" rows="2"
                class="mt-1 w-full border border-zinc-700 rounded px-3 py-2 text-sm"></textarea>
            </label>
          </div>

          <button type="submit"
            class="bg-brand-700 text-white px-5 py-2 rounded font-medium hover:bg-brand-900">
            Submit request
          </button>
          <p class="text-xs text-zinc-400 mt-3">
            No payment required now. We'll be in touch when the next order is placed.
          </p>
        </form>
      </div>
    </div>
  </div>
</PublicLayout>
