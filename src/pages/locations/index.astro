---
import PublicLayout from "~/layouts/PublicLayout.astro";
import { loadLocations } from "~/lib/queries";
import { osmEmbedUrl } from "~/lib/maps";

const locations = await loadLocations(Astro, { activeOnly: true });
---

<PublicLayout title="Locations" description="Where Chuckanut Sports Car Club runs autocross and other events.">
  <section class="border-b border-zinc-800 bg-zinc-900">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <p class="text-xs uppercase tracking-wider text-brand-700 font-semibold mb-2">Venues</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-3">Locations</h1>
      <p class="text-zinc-400 max-w-2xl">
        Where to find us. Click any venue for directions, parking notes, and a map.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-12">
    {locations.length === 0 ? (
      <p class="text-zinc-400">No venues listed yet.</p>
    ) : (
      <ul class="grid gap-6 md:grid-cols-2">
        {locations.map((loc) => {
          return (
            <li>
              <a
                href={`/locations/${loc.slug}`}
                class="group block bg-zinc-900 border border-zinc-800 rounded-lg overflow-hidden hover:border-brand-500 hover:shadow-md transition-all"
              >
                <div class="aspect-[16/9] bg-zinc-800 overflow-hidden">
                  {loc.map_image_key ? (
                    <img
                      src={`/media/${loc.map_image_key}`}
                      alt=""
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : loc.latitude !== null && loc.longitude !== null ? (
                    <iframe
                      src={osmEmbedUrl(loc.latitude, loc.longitude, 0.01)}
                      class="w-full h-full pointer-events-none"
                      loading="lazy"
                      title={`Map of ${loc.name}`}
                    ></iframe>
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-zinc-500 text-sm">
                      No map
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h2 class="font-display text-xl font-semibold mb-1">{loc.name}</h2>
                  {loc.address && (
                    <p class="text-sm text-zinc-400">📍 {loc.address}</p>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</PublicLayout>
