---
import PublicLayout from "~/layouts/PublicLayout.astro";
import EventCard from "~/components/public/EventCard.astro";
import {
  loadSettings,
  loadHomePage,
  loadUpcomingEvents,
} from "~/lib/queries";

const [settings, home, upcoming] = await Promise.all([
  loadSettings(Astro),
  loadHomePage(Astro),
  loadUpcomingEvents(Astro, 3),
]);

const heroTitle = home?.hero_title ?? settings.club_name ?? "Chuckanut Sports Car Club";
const heroSubtitle = home?.hero_subtitle ?? settings.tagline ?? "";
const heroImageKey = home?.hero_image_key;
const heroCtaText = home?.hero_cta_text ?? "See upcoming events";
const heroCtaUrl = home?.hero_cta_url ?? "/events";
---

<PublicLayout description={heroSubtitle}>
  <section class="relative isolate overflow-hidden bg-zinc-950 text-white">
    {heroImageKey && (
      <img
        src={`/media/${heroImageKey}`}
        alt=""
        class="absolute inset-0 -z-10 h-full w-full object-cover"
      />
    )}
    {/* Two-layer wash so the photo is visible up top, copy stays legible mid-band, gradient fades into the page bg. */}
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-zinc-950/40 via-zinc-950/65 to-zinc-950"></div>

    <div class="max-w-6xl mx-auto px-4 py-28 sm:py-36 text-center">
      <h1 class="font-display text-5xl sm:text-7xl font-bold mb-2 drop-shadow-md">
        {heroTitle}
      </h1>
      <p class="font-display text-3xl sm:text-5xl font-bold text-brand-500 mb-6 drop-shadow-md">
        since 1956.
      </p>
      <p class="text-lg sm:text-xl text-zinc-300 max-w-2xl mx-auto">{heroSubtitle}</p>
      <div class="mt-10 flex justify-center gap-3 flex-wrap">
        <a href={heroCtaUrl} class="bg-brand-500 text-white px-6 py-3 rounded font-medium hover:bg-brand-700 transition-colors">
          {heroCtaText}
        </a>
        <a href="/membership" class="border border-zinc-600 text-zinc-100 px-6 py-3 rounded font-medium hover:bg-zinc-900 transition-colors">
          Become a member
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-display text-3xl font-semibold">Upcoming events</h2>
      <a href="/events" class="text-sm text-brand-700 hover:underline">View all →</a>
    </div>

    {upcoming.length === 0 && (
      <p class="text-zinc-400">No events on the calendar right now. Check back soon.</p>
    )}

    {upcoming.length > 0 && (
      <ul class="grid gap-6 md:grid-cols-3">
        {upcoming.map((evt) => (
          <li>
            <EventCard event={evt} />
          </li>
        ))}
      </ul>
    )}
  </section>
</PublicLayout>
