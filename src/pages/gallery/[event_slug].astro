---
import PublicLayout from "~/layouts/PublicLayout.astro";
import PhotoMosaic, { type MosaicPhoto } from "~/components/public/PhotoMosaic.tsx";
import {
  loadEventBySlug,
  loadEventPhotographers,
  loadRecentPhotos,
} from "~/lib/queries";
import { fmtDate } from "~/lib/format";

const slug = Astro.params.event_slug!;
const evt = await loadEventBySlug(Astro, slug);

if (!evt) {
  return new Response("Not found", { status: 404 });
}

const [photographers, photos] = await Promise.all([
  loadEventPhotographers(Astro, evt.id),
  loadRecentPhotos(Astro, { eventId: evt.id, limit: 1000 }),
]);

const credit = photographers.length === 0
  ? null
  : photographers.length === 1
    ? [{ label: photographers[0].photographer_name, slug: photographers[0].photographer_slug, sep: "" }]
    : photographers.map((p, i) => ({
        label: p.photographer_name,
        slug: p.photographer_slug,
        sep: i === 0 ? "" : i === photographers.length - 1 ? " and " : ", ",
      }));

const mosaicPhotos: MosaicPhoto[] = photos.map((p) => ({
  id: p.id,
  thumb: p.r2_key_thumb,
  display: p.r2_key_display,
  full: p.r2_key_full,
  photographer: p.photographer_name,
  photographerSlug: p.photographer_slug,
  eventTitle: p.event_title,
  eventSlug: p.event_slug,
  width: p.width,
  height: p.height,
}));
---

<PublicLayout title={`Photos: ${evt.title}`}>
  <section class="border-b border-slate-200 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <a href="/gallery" class="text-sm text-brand-700 hover:underline">← All galleries</a>
      <h1 class="font-display text-4xl font-bold mt-4 mb-2">{evt.title}</h1>
      <p class="text-slate-600">{fmtDate(evt.start_at)} · {mosaicPhotos.length} photo{mosaicPhotos.length === 1 ? "" : "s"}</p>
      {credit && (
        <p class="text-sm text-slate-500 mt-2">
          Photos by{" "}
          {credit.map((c) => (
            <>
              {c.sep}
              <a href={`/photographers/${c.slug}`} class="text-brand-700 hover:underline">{c.label}</a>
            </>
          ))}
        </p>
      )}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-8">
    <PhotoMosaic client:load photos={mosaicPhotos} hideEventLabel={true} />
  </section>
</PublicLayout>
