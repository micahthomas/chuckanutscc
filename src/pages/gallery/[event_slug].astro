---
import PublicLayout from "~/layouts/PublicLayout.astro";
import PhotoMosaic, { type MosaicPhoto } from "~/components/public/PhotoMosaic.tsx";
import {
  countPhotos,
  loadEventBySlug,
  loadEventPhotographers,
  loadRecentPhotos,
} from "~/lib/queries";
import { fmtDate } from "~/lib/format";

const slug = Astro.params.event_slug!;
const evt = await loadEventBySlug(Astro, slug);

if (!evt) {
  return new Response("Not found", { status: 404 });
}

const [photographers, photos, totalPhotos] = await Promise.all([
  loadEventPhotographers(Astro, evt.id),
  loadRecentPhotos(Astro, { eventId: evt.id, limit: 200 }),
  countPhotos(Astro, { eventId: evt.id }),
]);

const credit = photographers.length === 0
  ? null
  : photographers.length === 1
    ? [{ label: photographers[0].photographer_name, slug: photographers[0].photographer_slug, sep: "" }]
    : photographers.map((p, i) => ({
        label: p.photographer_name,
        slug: p.photographer_slug,
        sep: i === 0 ? "" : i === photographers.length - 1 ? " and " : ", ",
      }));

const mosaicPhotos: MosaicPhoto[] = photos.map((p) => ({
  id: p.id,
  thumb: p.r2_key_thumb,
  display: p.r2_key_display,
  full: p.r2_key_full,
  photographer: p.photographer_name,
  photographerSlug: p.photographer_slug,
  eventTitle: p.event_title,
  eventSlug: p.event_slug,
  width: p.width,
  height: p.height,
}));
---

<PublicLayout title={`Photos: ${evt.title}`}>
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-6">
    <a href="/gallery" class="text-sm text-zinc-400 hover:text-zinc-200">← All galleries</a>
    <h1 class="font-display text-3xl sm:text-4xl font-bold mt-4 mb-3">{evt.title}</h1>
    <p class="text-zinc-400">{fmtDate(evt.start_at)} · {totalPhotos} photo{totalPhotos === 1 ? "" : "s"}</p>
      {credit && (
        <p class="text-sm text-zinc-400 mt-2">
          Photos by{" "}
          {credit.map((c) => (
            <>
              {c.sep}
              <a href={`/photographers/${c.slug}`} class="text-brand-500 hover:underline">{c.label}</a>
            </>
          ))}
        </p>
      )}
  </section>

  <section class="max-w-6xl mx-auto px-4 py-8">
    <PhotoMosaic
      client:load
      photos={mosaicPhotos}
      total={totalPhotos}
      eventSlug={slug}
      hideEventLabel={true}
    />
  </section>
</PublicLayout>
