---
import PublicLayout from "~/layouts/PublicLayout.astro";
import PhotoMosaic, { type MosaicPhoto } from "~/components/public/PhotoMosaic.tsx";
import { countPhotos, loadGalleryEvents, loadRecentPhotos } from "~/lib/queries";
import { db } from "~/lib/db";

const eventSlug = Astro.url.searchParams.get("event");

// Resolve slug → id (so the query can filter), or null for "all events".
let eventId: string | null = null;
let filteredEventTitle: string | null = null;
let filteredEventYear: number | null = null;
if (eventSlug) {
  const row = await db(Astro)
    .prepare(
      `SELECT e.id, e.title, s.year AS season_year
       FROM events e
       LEFT JOIN seasons s ON s.id = e.season_id
       WHERE e.slug = ?`,
    )
    .bind(eventSlug)
    .first<{ id: string; title: string; season_year: number | null }>();
  if (row) {
    eventId = row.id;
    filteredEventTitle = row.title;
    filteredEventYear = row.season_year;
  }
}

const [events, photos, totalPhotos] = await Promise.all([
  loadGalleryEvents(Astro),
  loadRecentPhotos(Astro, { eventId, limit: 200 }),
  countPhotos(Astro, { eventId }),
]);

const mosaicPhotos: MosaicPhoto[] = photos.map((p) => ({
  id: p.id,
  thumb: p.r2_key_thumb,
  display: p.r2_key_display,
  full: p.r2_key_full,
  photographer: p.photographer_name,
  photographerSlug: p.photographer_slug,
  eventTitle: p.event_title,
  eventSlug: p.event_slug,
  width: p.width,
  height: p.height,
}));
---

<PublicLayout title="Photo gallery" description="Photos from CSCC events.">
  <section class="border-b border-zinc-800 bg-zinc-900">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <p class="text-xs uppercase tracking-wider text-brand-700 font-semibold mb-2">Gallery</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-3">
        {filteredEventTitle && eventSlug ? (
          <a href={`/events/${eventSlug}`} class="hover:underline decoration-brand-500 underline-offset-4">
            {filteredEventTitle}
            {filteredEventYear && <span class="text-zinc-500 font-normal"> ({filteredEventYear})</span>}
          </a>
        ) : (
          "Photos from recent events"
        )}
      </h1>
      <p class="text-zinc-400 max-w-2xl">
        Click any photo to open the lightbox. Use ← / → or the thumbnail strip to browse.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-6">
    <h2 class="text-xs uppercase tracking-wider text-zinc-400 font-semibold mb-3">Filter by event</h2>
    <div class="flex flex-wrap gap-2">
      <a
        href="/gallery"
        class={`px-3 py-1.5 rounded-full border text-sm transition-colors ${
          !eventSlug
            ? "bg-brand-700 text-white border-brand-700"
            : "border-zinc-700 text-zinc-300 hover:bg-zinc-800"
        }`}
      >
        All photos
      </a>
      {events.map((e) => (
        <a
          href={`/gallery?event=${e.slug}`}
          class={`px-3 py-1.5 rounded-full border text-sm transition-colors ${
            eventSlug === e.slug
              ? "bg-brand-700 text-white border-brand-700"
              : "border-zinc-700 text-zinc-300 hover:bg-zinc-800"
          }`}
        >
          {e.title}
          {e.season_year && (
            <span class={`ml-1 ${eventSlug === e.slug ? "text-white/80" : "text-zinc-400"}`}>
              ({e.season_year})
            </span>
          )}
          <span class={`ml-1 text-xs ${eventSlug === e.slug ? "text-white/70" : "text-zinc-500"}`}>
            {e.photo_count}
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-16">
    <PhotoMosaic
      client:load
      photos={mosaicPhotos}
      total={totalPhotos}
      eventSlug={eventSlug}
      hideEventLabel={!!eventSlug}
    />

    {mosaicPhotos.length === 0 && events.length === 0 && (
      <p class="text-zinc-400 mt-8">No event photos uploaded yet. Check back after the next event.</p>
    )}
  </section>
</PublicLayout>
