---
import PublicLayout from "~/layouts/PublicLayout.astro";
import { loadPhotographers } from "~/lib/queries";

const photographers = (await loadPhotographers(Astro, { activeOnly: true })).map((p) => ({
  ...p,
  bioPreview: p.bio_md ? p.bio_md.replace(/[#*_`]/g, "").slice(0, 140) : null,
}));
---

<PublicLayout title="Photographers" description="Club photographers.">
  <section class="border-b border-zinc-800 bg-zinc-900">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-500 mb-3">Team</div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-3">Photographers</h1>
      <p class="text-zinc-400 max-w-2xl">The people who make the photos happen.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-12">
    {photographers.length === 0 ? (
      <p class="text-zinc-400">No photographers listed yet.</p>
    ) : (
      <ul class="grid gap-4 sm:grid-cols-2">
        {photographers.map((p) => (
          <li>
            <a
              href={`/photographers/${p.slug}`}
              class="block bg-zinc-900 border border-zinc-800 rounded-lg p-5 hover:border-brand-500 transition-colors"
            >
              <h2 class="font-semibold text-lg mb-1">{p.name}</h2>
              {p.bioPreview && <p class="text-sm text-zinc-400 line-clamp-2">{p.bioPreview}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</PublicLayout>
