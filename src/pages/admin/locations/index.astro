---
import AdminLayout from "~/layouts/AdminLayout.astro";
import { loadLocations } from "~/lib/queries";

const locations = await loadLocations(Astro);
const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title="Locations">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Locations</h1>
    <a href="/admin/locations/new" class="bg-brand-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-brand-900">
      + New location
    </a>
  </div>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
    {locations.length === 0 ? (
      <p class="p-4 text-sm text-slate-500">No locations yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs text-slate-500 uppercase">
          <tr>
            <th class="px-4 py-2">Name</th>
            <th class="px-4 py-2">Address</th>
            <th class="px-4 py-2">Coords</th>
            <th class="px-4 py-2">Active</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {locations.map((l) => (
            <tr class="border-t border-slate-100">
              <td class="px-4 py-2">
                <a href={`/admin/locations/${l.id}`} class="text-brand-700 font-medium hover:underline">{l.name}</a>
              </td>
              <td class="px-4 py-2 text-slate-500 text-xs">{l.address ?? "—"}</td>
              <td class="px-4 py-2 text-slate-500 text-xs font-mono">
                {l.latitude != null && l.longitude != null ? `${l.latitude.toFixed(4)}, ${l.longitude.toFixed(4)}` : "—"}
              </td>
              <td class="px-4 py-2">
                {l.active === 1 ? <span class="text-emerald-700">Yes</span> : <span class="text-slate-400">No</span>}
              </td>
              <td class="px-4 py-2 text-right">
                <a href={`/locations/${l.slug}`} target="_blank" class="text-xs text-slate-500 hover:underline">View public →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
