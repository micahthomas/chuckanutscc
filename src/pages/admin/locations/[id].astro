---
import AdminLayout from "~/layouts/AdminLayout.astro";
import LocationForm from "~/components/admin/LocationForm.astro";
import { loadLocation } from "~/lib/queries";

const id = Astro.params.id!;
const loc = await loadLocation(Astro, id);
if (!loc) return new Response("Not found", { status: 404 });

const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title={`Edit: ${loc.name}`}>
  <a href="/admin/locations" class="text-sm text-brand-700 hover:underline">← Locations</a>
  <div class="flex items-center justify-between mt-2 mb-6">
    <h1 class="text-2xl font-semibold">{loc.name}</h1>
    <a href={`/locations/${loc.slug}`} target="_blank" class="text-sm text-slate-500 hover:underline">View public →</a>
  </div>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <LocationForm loc={loc} />

  <section class="mt-12 max-w-2xl border-t border-slate-200 pt-6">
    <h2 class="text-lg font-semibold mb-3 text-red-700">Danger zone</h2>
    <form method="post" action="/admin/api/locations/delete" onsubmit="return confirm('Delete this location? Events that reference it will lose the link (but otherwise remain).')">
      <input type="hidden" name="id" value={loc.id} />
      <button class="text-sm text-red-700 border border-red-200 px-3 py-1 rounded hover:bg-red-50">
        Delete location
      </button>
    </form>
  </section>
</AdminLayout>
