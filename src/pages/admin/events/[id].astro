---
import AdminLayout from "~/layouts/AdminLayout.astro";
import EventForm from "~/components/admin/EventForm.astro";
import { db } from "~/lib/db";
import {
  loadEventPhotographers,
  loadPhotographers,
} from "~/lib/queries";

const id = Astro.params.id!;
const evt = await db(Astro)
  .prepare(
    `SELECT id, slug, title, event_type, status, start_at, end_at,
            season_id,
            location_id, location_name, location_address, location_map_url,
            description_md, registration_url, results_url,
            run_groups_json, fee_member_cents, fee_nonmember_cents,
            hero_image_key, course_map_image_key
     FROM events WHERE id = ?`,
  )
  .bind(id)
  .first<Parameters<typeof EventForm>[0]["evt"]>();

if (!evt) {
  return new Response("Event not found", { status: 404 });
}

const [photographers, allPhotographers] = await Promise.all([
  loadEventPhotographers(Astro, evt.id),
  loadPhotographers(Astro, { activeOnly: true }),
]);
const assignedIds = new Set(photographers.map((p) => p.photographer_id));
const unassigned = allPhotographers.filter((p) => !assignedIds.has(p.id));

const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title={`Edit: ${evt.title}`}>
  <a href="/admin/events" class="text-sm text-brand-700 hover:underline">← Events</a>
  <div class="flex items-center justify-between mt-2 mb-1">
    <h1 class="text-2xl font-semibold">{evt.title}</h1>
    <a href={`/events/${evt.slug}`} target="_blank" class="text-sm text-slate-500 hover:underline">
      View public →
    </a>
  </div>
  <p class="text-xs text-slate-400 mb-6">ID: <code class="font-mono">{evt.id}</code></p>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <EventForm evt={evt} />

  <section class="mt-12 max-w-3xl">
    <h2 class="text-lg font-semibold mb-3">Photographers</h2>

    {photographers.length === 0 ? (
      <p class="text-sm text-slate-500 mb-4">None assigned yet.</p>
    ) : (
      <ul class="space-y-2 mb-4">
        {photographers.map((p) => (
          <li class="bg-white border border-slate-200 rounded p-3 flex items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="font-medium">{p.photographer_name}</div>
              {p.notes && <div class="text-xs text-slate-400 mt-1">{p.notes}</div>}
            </div>
            <a
              href={`/admin/photographers/${p.photographer_id}`}
              class="text-xs text-slate-500 hover:underline"
            >
              Upload URL →
            </a>
            <form method="post" action="/admin/api/events/photographers/remove">
              <input type="hidden" name="event_id" value={evt.id} />
              <input type="hidden" name="ep_id" value={p.id} />
              <button class="text-xs text-red-600 hover:underline">Remove</button>
            </form>
          </li>
        ))}
      </ul>
    )}

    {unassigned.length > 0 ? (
      <form method="post" action="/admin/api/events/photographers/add" class="border border-slate-200 rounded p-4 bg-slate-50">
        <input type="hidden" name="event_id" value={evt.id} />
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <label class="block sm:col-span-1">
            <span class="text-xs text-slate-500">Photographer</span>
            <select name="photographer_id" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm bg-white">
              <option value="">— select —</option>
              {unassigned.map((p) => <option value={p.id}>{p.name}</option>)}
            </select>
          </label>
          <label class="block sm:col-span-2">
            <span class="text-xs text-slate-500">Notes (optional, officer-only)</span>
            <input
              type="text"
              name="notes"
              class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm"
            />
          </label>
        </div>
        <button class="mt-3 bg-brand-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-brand-900">
          Assign photographer
        </button>
      </form>
    ) : (
      <p class="text-sm text-slate-500">
        All known photographers are already assigned to this event.
        <a href="/admin/photographers/new" class="text-brand-700 hover:underline">Add another?</a>
      </p>
    )}
  </section>

  <section class="mt-12 max-w-3xl border-t border-slate-200 pt-6">
    <h2 class="text-lg font-semibold mb-3 text-red-700">Danger zone</h2>
    <form method="post" action="/admin/api/events/delete" onsubmit="return confirm('Delete this event? Photos and assignments will be removed too.')">
      <input type="hidden" name="id" value={evt.id} />
      <button class="text-sm text-red-700 border border-red-200 px-3 py-1 rounded hover:bg-red-50">
        Delete event
      </button>
    </form>
  </section>
</AdminLayout>
