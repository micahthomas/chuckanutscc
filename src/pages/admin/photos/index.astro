---
import AdminLayout from "~/layouts/AdminLayout.astro";
import { db } from "~/lib/db";
import { fmtDateTime } from "~/lib/format";

const status = (Astro.url.searchParams.get("status") ?? "live") as "live" | "hidden" | "rejected" | "all";
const where = status === "all" ? "" : "WHERE ph.status = ?";
const binds: unknown[] = status === "all" ? [] : [status];

const { results: photos } = await db(Astro)
  .prepare(
    `SELECT ph.id, ph.event_id, ph.status, ph.r2_key_thumb, ph.uploaded_at, ph.filename,
            e.title AS event_title, e.slug AS event_slug,
            p.name AS photographer_name
     FROM photos ph
     JOIN events e ON e.id = ph.event_id
     JOIN photographers p ON p.id = ph.photographer_id
     ${where}
     ORDER BY ph.uploaded_at DESC
     LIMIT 200`,
  )
  .bind(...binds)
  .all<{
    id: string; event_id: string; status: string; r2_key_thumb: string;
    uploaded_at: number; filename: string;
    event_title: string; event_slug: string; photographer_name: string;
  }>();

const counts = await db(Astro)
  .prepare(
    `SELECT
       SUM(CASE WHEN status='live' THEN 1 ELSE 0 END) AS live,
       SUM(CASE WHEN status='hidden' THEN 1 ELSE 0 END) AS hidden,
       SUM(CASE WHEN status='rejected' THEN 1 ELSE 0 END) AS rejected
     FROM photos`,
  )
  .first<{ live: number; hidden: number; rejected: number }>();

const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title="Photos">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Photos</h1>
    <a
      href="/admin/photographers"
      class="text-sm text-brand-700 hover:underline"
    >
      Manage photographers →
    </a>
  </div>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <div class="flex gap-2 mb-6 text-sm">
    {(["live", "hidden", "rejected", "all"] as const).map((s) => (
      <a
        href={`/admin/photos?status=${s}`}
        class={`px-3 py-1.5 rounded border ${status === s ? "bg-brand-700 text-white border-brand-700" : "border-slate-300 text-slate-700 hover:bg-slate-50"}`}
      >
        {s} {s !== "all" && <span class="opacity-70">({counts?.[s] ?? 0})</span>}
      </a>
    ))}
  </div>

  {photos.length === 0 ? (
    <p class="text-slate-500">
      No photos in this view.
      {status === "live" && counts?.live === 0 && (
        <> Photographers upload via their personal URL on the photographer page.</>
      )}
    </p>
  ) : (
    <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {photos.map((ph) => (
        <div class="bg-white border border-slate-200 rounded overflow-hidden">
          <a href={`/media/${ph.r2_key_thumb}`} target="_blank">
            <img src={`/media/${ph.r2_key_thumb}`} alt={ph.filename} class="w-full aspect-square object-cover" loading="lazy" />
          </a>
          <div class="p-2 text-xs">
            <div class="font-medium truncate">{ph.event_title}</div>
            <div class="text-slate-500 truncate">{ph.photographer_name}</div>
            <div class="text-slate-400 mt-1">{fmtDateTime(ph.uploaded_at)}</div>
            <div class="mt-2 flex gap-1">
              {ph.status !== "live" && (
                <form method="post" action="/admin/api/photos/set-status" class="inline">
                  <input type="hidden" name="id" value={ph.id} />
                  <input type="hidden" name="status" value="live" />
                  <button class="text-emerald-700 hover:underline">Show</button>
                </form>
              )}
              {ph.status === "live" && (
                <form method="post" action="/admin/api/photos/set-status" class="inline">
                  <input type="hidden" name="id" value={ph.id} />
                  <input type="hidden" name="status" value="hidden" />
                  <button class="text-amber-700 hover:underline">Hide</button>
                </form>
              )}
              {ph.status !== "rejected" && (
                <form method="post" action="/admin/api/photos/set-status" class="inline">
                  <input type="hidden" name="id" value={ph.id} />
                  <input type="hidden" name="status" value="rejected" />
                  <button class="text-red-700 hover:underline">Reject</button>
                </form>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</AdminLayout>
