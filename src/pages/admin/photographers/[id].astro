---
import AdminLayout from "~/layouts/AdminLayout.astro";
import PhotographerForm from "~/components/admin/PhotographerForm.astro";
import { db } from "~/lib/db";
import { env } from "cloudflare:workers";

const id = Astro.params.id!;
const photographer = await db(Astro)
  .prepare(
    `SELECT id, slug, name, bio_md, portfolio_url, instagram_url, contact_email, active, upload_token
     FROM photographers WHERE id = ?`,
  )
  .bind(id)
  .first<Parameters<typeof PhotographerForm>[0]["photographer"] & { upload_token: string }>();

if (!photographer) {
  return new Response("Not found", { status: 404 });
}

const flash = Astro.url.searchParams.get("flash");
const siteOrigin = env.PUBLIC_SITE_URL ?? Astro.url.origin;
const uploadUrl = `${siteOrigin.replace(/\/$/, "")}/p/${photographer.upload_token}`;
---

<AdminLayout title={`Edit: ${photographer.name}`}>
  <a href="/admin/photographers" class="text-sm text-brand-700 hover:underline">← Photographers</a>
  <div class="flex items-center justify-between mt-2 mb-6">
    <h1 class="text-2xl font-semibold">{photographer.name}</h1>
    <a href={`/photographers/${photographer.slug}`} target="_blank" class="text-sm text-slate-500 hover:underline">View public →</a>
  </div>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <section class="max-w-2xl mb-8 bg-white border border-slate-200 rounded p-4">
    <h2 class="text-sm font-semibold text-slate-700 mb-2">Upload URL</h2>
    <p class="text-xs text-slate-500 mb-3">
      Share this with the photographer. It's the only credential needed to
      upload to their assigned events. Regenerate if it leaks.
    </p>
    <div class="flex items-stretch gap-2">
      <input
        id="upload-url"
        type="text"
        readonly
        value={uploadUrl}
        class="flex-1 border border-slate-300 rounded px-3 py-2 text-sm font-mono bg-slate-50"
      />
      <button
        type="button"
        id="copy-upload-url"
        class="px-3 py-2 text-sm border border-slate-300 rounded hover:bg-slate-50"
      >
        Copy
      </button>
      <a
        href={uploadUrl}
        target="_blank"
        class="px-3 py-2 text-sm border border-slate-300 rounded hover:bg-slate-50"
      >
        Open
      </a>
    </div>
    <form
      method="post"
      action="/admin/api/photographers/regenerate-token"
      onsubmit="return confirm('Regenerate URL? The current URL will stop working immediately.')"
      class="mt-3"
    >
      <input type="hidden" name="id" value={photographer.id} />
      <button class="text-xs text-red-700 hover:underline">Regenerate URL</button>
    </form>
  </section>

  <PhotographerForm photographer={photographer} />

  <section class="mt-12 max-w-2xl border-t border-slate-200 pt-6">
    <h2 class="text-lg font-semibold mb-3 text-red-700">Danger zone</h2>
    <form method="post" action="/admin/api/photographers/delete" onsubmit="return confirm('Delete this photographer? Their event assignments and photos will be blocked.')">
      <input type="hidden" name="id" value={photographer.id} />
      <button class="text-sm text-red-700 border border-red-200 px-3 py-1 rounded hover:bg-red-50">
        Delete photographer
      </button>
    </form>
  </section>

  <script is:inline>
    document.getElementById("copy-upload-url")?.addEventListener("click", async (e) => {
      const btn = e.currentTarget;
      const input = document.getElementById("upload-url");
      try {
        await navigator.clipboard.writeText(input.value);
        const orig = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = orig; }, 1500);
      } catch {
        input.select();
        document.execCommand("copy");
      }
    });
  </script>
</AdminLayout>
