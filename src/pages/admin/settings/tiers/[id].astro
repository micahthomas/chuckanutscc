---
import AdminLayout from "~/layouts/AdminLayout.astro";
import MarkdownEditor from "~/components/admin/MarkdownEditor.tsx";
import { loadMembershipTier } from "~/lib/queries";

const id = Astro.params.id!;
const tier = await loadMembershipTier(Astro, id);
if (!tier) return new Response("Not found", { status: 404 });

const benefits: string[] = JSON.parse(tier.benefits_json || "[]");
const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title={`Tier: ${tier.name}`}>
  <a href="/admin/settings" class="text-sm text-brand-700 hover:underline">← Settings</a>
  <h1 class="text-2xl font-semibold mt-2 mb-6">{tier.name} tier</h1>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <form method="post" action="/admin/api/settings/tier-save" class="space-y-5 max-w-2xl">
    <input type="hidden" name="id" value={tier.id} />

    <label class="block">
      <span class="text-sm font-medium text-slate-700">Name</span>
      <input type="text" name="name" value={tier.name} required
        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm" />
    </label>

    <label class="block">
      <span class="text-sm font-medium text-slate-700">Annual price (cents)</span>
      <input type="number" name="annual_price_cents" value={tier.annual_price_cents} min="0" required
        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm" />
      <p class="text-xs text-slate-400 mt-1">7500 = $75.00</p>
    </label>

    <MarkdownEditor
      client:load
      name="description_md"
      defaultValue={tier.description_md ?? ""}
      label="Description"
      rows={5}
    />

    <label class="block">
      <span class="text-sm font-medium text-slate-700">Benefits (one per line)</span>
      <textarea name="benefits" rows="5"
        placeholder="Discounted event entry&#10;Quarterly newsletter&#10;Member-only events"
        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm"
      >{benefits.join("\n")}</textarea>
    </label>

    <label class="flex items-center gap-2">
      <input type="checkbox" name="visible" checked={tier.visible === 1} />
      <span class="text-sm font-medium text-slate-700">Visible on /membership page</span>
    </label>

    <div class="pt-4 border-t border-slate-200">
      <button type="submit" class="bg-brand-700 text-white px-5 py-2 rounded font-medium hover:bg-brand-900">
        Save tier
      </button>
    </div>
  </form>
</AdminLayout>
