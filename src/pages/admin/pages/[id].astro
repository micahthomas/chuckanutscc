---
import AdminLayout from "~/layouts/AdminLayout.astro";
import PageForm from "~/components/admin/PageForm.astro";
import { db } from "~/lib/db";

const id = Astro.params.id!;
const page = await db(Astro)
  .prepare(
    `SELECT id, slug, title, body_md, show_in_nav, nav_order, seo_title, seo_description
     FROM pages WHERE id = ?`,
  )
  .bind(id)
  .first<Parameters<typeof PageForm>[0]["page"]>();

if (!page) {
  return new Response("Not found", { status: 404 });
}

const flash = Astro.url.searchParams.get("flash");
---

<AdminLayout title={`Edit: ${page.title}`}>
  <a href="/admin/pages" class="text-sm text-brand-700 hover:underline">← Pages</a>
  <div class="flex items-center justify-between mt-2 mb-6">
    <h1 class="text-2xl font-semibold">{page.title}</h1>
    <a href={`/${page.slug}`} target="_blank" class="text-sm text-slate-500 hover:underline">View public →</a>
  </div>

  {flash && (
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-900 rounded p-3 mb-4 text-sm">{flash}</div>
  )}

  <PageForm page={page} />

  <section class="mt-12 max-w-3xl border-t border-slate-200 pt-6">
    <h2 class="text-lg font-semibold mb-3 text-red-700">Danger zone</h2>
    <form method="post" action="/admin/api/pages/delete" onsubmit="return confirm('Delete this page?')">
      <input type="hidden" name="id" value={page.id} />
      <button class="text-sm text-red-700 border border-red-200 px-3 py-1 rounded hover:bg-red-50">
        Delete page
      </button>
    </form>
  </section>
</AdminLayout>
