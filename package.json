{
  "name": "cscc-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "check": "astro check",
    "typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply cscc --local",
    "db:migrate:remote": "wrangler d1 migrations apply cscc --remote",
    "db:seed:local": "node scripts/seed-local.mjs",
    "db:seed:remote": "node scripts/seed-remote.mjs",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && pnpm db:migrate:local",
    "media:push:remote": "node scripts/push-r2-to-remote.mjs",
    "demo": "pnpm db:reset:local && pnpm db:seed:local && pnpm dev"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.4",
    "@astrojs/react": "^5.0.5",
    "@tailwindcss/vite": "^4.0.0",
    "@zip.js/zip.js": "^2.8.26",
    "astro": "^6.3.7",
    "leaflet": "^1.9.4",
    "marked": "^18.0.4",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "exifr": "^7.1.3",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
